# Copy to .env and fill in. All vars are prefixed E2E_HEALER_ (see app/config.py).

# LLM provider (provider-neutral). Select the backend, then configure it with the generic
# LLM_* vars below. Default provider is nvidia for backward compatibility.
E2E_HEALER_LLM_PROVIDER=nvidia
E2E_HEALER_LLM_API_KEY=
E2E_HEALER_LLM_BASE_URL=
E2E_HEALER_LLM_MODEL=
E2E_HEALER_LLM_MAX_TOKENS=4096

# --- OpenAI example ---------------------------------------------------------------
# Drop in an existing OpenAI key: set the provider and either E2E_HEALER_LLM_API_KEY or
# the standard OPENAI_API_KEY (used as a fallback). Uses native strict Structured Outputs.
#   E2E_HEALER_LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...            # or E2E_HEALER_LLM_API_KEY=sk-...
#   E2E_HEALER_LLM_MODEL=gpt-4o-mini
#   E2E_HEALER_LLM_BASE_URL=         # set for Azure / OpenAI-compatible endpoints
# ------------------------------------------------------------------------------------

# --- Anthropic (Claude) example ------------------------------------------------------
# Requires the optional extra: pip install "ai-driven-e2e[anthropic]". Set the provider and
# either E2E_HEALER_LLM_API_KEY or the standard ANTHROPIC_API_KEY (fallback). Structured
# outputs map onto Claude tool-use.
#   E2E_HEALER_LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...     # or E2E_HEALER_LLM_API_KEY=sk-ant-...
#   E2E_HEALER_LLM_MODEL=claude-sonnet-4-6
# ------------------------------------------------------------------------------------

# --- Ollama (local, offline) example -------------------------------------------------
# Requires the optional extra: pip install "ai-driven-e2e[ollama]". Fully local, no API key.
# Uses Ollama's native JSON-schema structured output. Pick a tool/structured-output-capable
# model (e.g. llama3.1, qwen2.5-coder, mistral-nemo). Default endpoint http://localhost:11434.
#   E2E_HEALER_LLM_PROVIDER=ollama
#   E2E_HEALER_LLM_MODEL=llama3.1
#   E2E_HEALER_LLM_BASE_URL=         # override only for a remote Ollama host
# ------------------------------------------------------------------------------------

# Legacy NVIDIA NIM vars (OpenAI-compatible Structured Outputs). Still supported: when
# LLM_PROVIDER=nvidia these are folded into the generic LLM_* vars above, so existing
# setups keep working unchanged. New configs should prefer the LLM_* vars.
E2E_HEALER_NVIDIA_API_KEY=nvapi-...
E2E_HEALER_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
E2E_HEALER_NVIDIA_MODEL=openai/gpt-oss-120b
E2E_HEALER_NVIDIA_MAX_TOKENS=4096

# Repair loop
E2E_HEALER_MAX_LOOPS=3

# Playwright invocation used by the Test Runner node
E2E_HEALER_PLAYWRIGHT_CMD=npx playwright test

# Selector Verifier — check patched selectors against the live DOM before re-running.
# Verification is skipped (loop proceeds unverified) when APP_URL is empty or unreachable.
E2E_HEALER_VERIFY_SELECTORS=true
E2E_HEALER_APP_URL=
E2E_HEALER_NODE_CMD=node

# Sandbox — relaxed blocks dangerous paths; strict also enforces workspace/write globs.
E2E_HEALER_SANDBOX_MODE=relaxed
E2E_HEALER_WORKSPACE_ROOT=.
E2E_HEALER_WRITE_GLOBS=*.spec.js,*.spec.jsx,*.spec.ts,*.spec.tsx,*.test.js,*.test.jsx,*.test.ts,*.test.tsx,**/*.spec.js,**/*.spec.jsx,**/*.spec.ts,**/*.spec.tsx,**/*.test.js,**/*.test.jsx,**/*.test.ts,**/*.test.tsx
E2E_HEALER_DENY_GLOBS=.env,.env.*,**/.env,**/.env.*,.git/**,.github/**,node_modules/**,.venv/**,uv.lock,package-lock.json,pnpm-lock.yaml,yarn.lock
E2E_HEALER_ALLOW_TEMP_HELPER=true

# Logging
E2E_HEALER_LOG_LEVEL=INFO
